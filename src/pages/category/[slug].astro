---
import Layout from "../../layouts/Layout.astro";
import { tools } from "../../data/tools";
import { CATEGORIES, FEATURE_LABELS } from "../../types";
import type { Category, Tool } from "../../types";

export function getStaticPaths() {
  return CATEGORIES.map((cat) => ({ params: { slug: cat.slug } }));
}

const { slug } = Astro.params;
const category = CATEGORIES.find((c) => c.slug === slug)!;
const categoryTools = tools.filter(
  (t) => t.primaryCategory === slug || t.secondaryCategories?.includes(slug as Category)
);
---

<Layout title={`${category.name} — Awesome Agent IDEs`} description={category.description}>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="mb-8">
      <a href="/" class="text-sm text-text-muted hover:text-accent transition-colors">← All categories</a>
    </div>

    <header class="mb-10">
      <div class="flex items-center gap-3 mb-2">
        <span class="font-mono text-sm font-medium text-accent bg-accent/10 px-2 py-1 tracking-wider">{category.icon}</span>
        <h1 class="text-3xl font-semibold">{category.name}</h1>
        <span class="text-sm font-mono text-text-muted">
          {categoryTools.length}
        </span>
      </div>
      <p class="text-text-muted text-lg">{category.description}</p>
    </header>

    {categoryTools.length <= 1 && (
      <div class="bg-yellow/5 border border-yellow/20  p-4 mb-8 text-sm text-yellow">
        This category is new. Know a tool that belongs here?{" "}
        <a href="https://github.com/mulyoved/awesome-agent-ides" class="underline">Open a PR</a>.
      </div>
    )}

    <!-- Filters -->
    <div id="filters" class="mb-6 flex flex-wrap gap-3 text-sm">
      <div class="relative">
        <label class="text-text-muted text-xs block mb-1">Platform</label>
        <div class="flex gap-2">
          {["macos", "windows", "linux", "web"].map((p) => (
            <label class="flex items-center gap-1 cursor-pointer text-text-muted hover:text-text">
              <input type="checkbox" value={p} class="filter-platform accent-accent" />
              <span class="text-xs">{p}</span>
            </label>
          ))}
        </div>
      </div>
      <div>
        <label class="text-text-muted text-xs block mb-1">Pricing</label>
        <div class="flex gap-2">
          {["free", "freemium", "paid", "byok"].map((p) => (
            <label class="flex items-center gap-1 cursor-pointer text-text-muted hover:text-text">
              <input type="checkbox" value={p} class="filter-pricing accent-accent" />
              <span class="text-xs">{p}</span>
            </label>
          ))}
        </div>
      </div>
      <div>
        <label class="text-text-muted text-xs block mb-1">Search</label>
        <input
          type="text"
          id="filter-search"
          placeholder="Filter tools..."
          class="bg-surface border border-border px-3 py-1.5 text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:border-accent w-48"
        />
      </div>
    </div>

    <!-- Tool cards -->
    <div id="tool-list" class="space-y-3">
      {categoryTools
        .sort((a, b) => a.name.localeCompare(b.name))
        .map((tool) => {
          const isSecondary = tool.primaryCategory !== slug;
          return (
            <a
              href={`/tool/${tool.slug}`}
              class="tool-card block  border border-border p-5 hover:border-accent/50 hover:bg-surface-hover transition-all"
              data-platforms={tool.platforms.join(",")}
              data-pricing={tool.pricing.model}
              data-search={`${tool.name} ${tool.description}`.toLowerCase()}
            >
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <h2 class="font-semibold text-accent text-base">{tool.name}</h2>
                    {isSecondary && (
                      <span class="text-xs text-text-muted bg-surface px-1.5 py-0.5">
                        Also a {CATEGORIES.find((c) => c.slug === tool.primaryCategory)!.name.toLowerCase().replace(/s$/, "")}
                      </span>
                    )}
                    {tool.status === "beta" && (
                      <span class="text-xs text-yellow bg-yellow/10 px-1.5 py-0.5">beta</span>
                    )}
                    {tool.status === "acquired" && (
                      <span class="text-xs text-red bg-red/10 px-1.5 py-0.5">acquired</span>
                    )}
                  </div>
                  <p class="text-sm text-text-muted mb-2">{tool.description}</p>
                  {tool.bestFor && (
                    <p class="text-xs text-green">Best for: {tool.bestFor}</p>
                  )}
                </div>
                <div class="flex flex-col items-end gap-1 shrink-0">
                  <span
                    class:list={[
                      "text-xs px-2 py-0.5",
                      tool.pricing.model === "free" && "text-green bg-green/10",
                      tool.pricing.model === "freemium" && "text-blue bg-blue/10",
                      tool.pricing.model === "paid" && "text-yellow bg-yellow/10",
                      tool.pricing.model === "byok" && "text-text-muted bg-surface",
                    ]}
                  >
                    {tool.pricing.model}
                    {tool.pricing.startingPrice && ` · ${tool.pricing.startingPrice}`}
                  </span>
                  <span class="text-xs text-text-muted font-mono">
                    {tool.platforms.join(" · ")}
                  </span>
                  <span class="text-xs text-text-muted font-mono">{tool.license}</span>
                </div>
              </div>
              {tool.features && (
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {Object.entries(tool.features)
                    .filter(([, v]) => v)
                    .map(([k]) => (
                      <span class="text-xs bg-accent/10 text-accent/80 px-2 py-0.5">
                        {FEATURE_LABELS[k as keyof typeof FEATURE_LABELS]}
                      </span>
                    ))}
                </div>
              )}
            </a>
          );
        })}
    </div>
    <p id="no-results" class="hidden text-text-muted text-center py-8">No tools match your filters.</p>
  </div>

  <script>
    function setupFilters() {
      const cards = document.querySelectorAll<HTMLElement>(".tool-card");
      const noResults = document.getElementById("no-results")!;
      const searchInput = document.getElementById("filter-search") as HTMLInputElement;
      const platformChecks = document.querySelectorAll<HTMLInputElement>(".filter-platform");
      const pricingChecks = document.querySelectorAll<HTMLInputElement>(".filter-pricing");

      function applyFilters() {
        const platforms = [...platformChecks].filter((c) => c.checked).map((c) => c.value);
        const pricing = [...pricingChecks].filter((c) => c.checked).map((c) => c.value);
        const search = searchInput.value.toLowerCase();

        let visible = 0;
        cards.forEach((card) => {
          const cardPlatforms = card.dataset.platforms!.split(",");
          const cardPricing = card.dataset.pricing!;
          const cardSearch = card.dataset.search!;

          const matchPlatform = platforms.length === 0 || platforms.some((p) => cardPlatforms.includes(p));
          const matchPricing = pricing.length === 0 || pricing.includes(cardPricing);
          const matchSearch = !search || cardSearch.includes(search);

          const show = matchPlatform && matchPricing && matchSearch;
          card.style.display = show ? "" : "none";
          if (show) visible++;
        });
        noResults.classList.toggle("hidden", visible > 0);
      }

      platformChecks.forEach((c) => c.addEventListener("change", applyFilters));
      pricingChecks.forEach((c) => c.addEventListener("change", applyFilters));
      searchInput.addEventListener("input", applyFilters);
    }
    setupFilters();
  </script>
</Layout>
