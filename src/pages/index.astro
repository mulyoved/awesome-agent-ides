---
import Layout from "../layouts/Layout.astro";
import { tools } from "../data/tools";
import { CATEGORIES } from "../types";
import type { Category } from "../types";

const toolsByCategory = CATEGORIES.map((cat) => {
  const count = tools.filter(
    (t) => t.primaryCategory === cat.slug || t.secondaryCategories?.includes(cat.slug)
  ).length;
  return { ...cat, count };
});
---

<Layout title="Awesome Agent IDEs — AI Coding Tool Landscape">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <header class="text-center mb-16">
      <h1 class="text-4xl font-bold mb-4">
        The Agent IDE Landscape
      </h1>
      <p class="text-text-muted text-lg max-w-2xl mx-auto">
        40+ AI coding tools across 7 categories. Stop comparing terminals to orchestrators.
        Find the right tool for <em>your</em> workflow.
      </p>
      <p class="text-text-muted text-sm mt-4">
        {tools.length} tools · Last updated March 2026
      </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {toolsByCategory.map((cat) => (
        <a
          href={`/category/${cat.slug}`}
          class:list={[
            "group block rounded-lg border border-border p-6 transition-all hover:border-accent/50 hover:bg-surface-hover",
            cat.count <= 1 && "opacity-70",
          ]}
        >
          <div class="flex items-start justify-between mb-3">
            <span class="text-2xl">{cat.icon}</span>
            <span class="text-xs font-mono text-text-muted bg-surface px-2 py-1 rounded">
              {cat.count} {cat.count === 1 ? "tool" : "tools"}
            </span>
          </div>
          <h2 class="text-lg font-semibold mb-1 group-hover:text-accent transition-colors">
            {cat.name}
          </h2>
          <p class="text-sm text-text-muted leading-relaxed">
            {cat.description}
          </p>
          {cat.count <= 1 && (
            <span class="inline-block mt-3 text-xs text-yellow px-2 py-0.5 border border-yellow/30 rounded">
              Emerging
            </span>
          )}
        </a>
      ))}
    </div>

    <section class="mt-20">
      <h2 class="text-2xl font-semibold mb-6">All Tools</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border text-left text-text-muted">
              <th class="pb-3 pr-4 font-medium">Name</th>
              <th class="pb-3 pr-4 font-medium">Category</th>
              <th class="pb-3 pr-4 font-medium hidden sm:table-cell">Platforms</th>
              <th class="pb-3 pr-4 font-medium hidden md:table-cell">Pricing</th>
              <th class="pb-3 font-medium hidden lg:table-cell">License</th>
            </tr>
          </thead>
          <tbody>
            {tools
              .sort((a, b) => a.name.localeCompare(b.name))
              .map((tool) => {
                const cat = CATEGORIES.find((c) => c.slug === tool.primaryCategory)!;
                return (
                  <tr class="border-b border-border/50 hover:bg-surface-hover transition-colors">
                    <td class="py-3 pr-4">
                      <a href={`/tool/${tool.slug}`} class="text-accent hover:text-accent-hover font-medium">
                        {tool.name}
                      </a>
                    </td>
                    <td class="py-3 pr-4 text-text-muted">{cat.name}</td>
                    <td class="py-3 pr-4 text-text-muted hidden sm:table-cell font-mono text-xs">
                      {tool.platforms.join(", ")}
                    </td>
                    <td class="py-3 pr-4 hidden md:table-cell">
                      <span
                        class:list={[
                          "text-xs px-2 py-0.5 rounded",
                          tool.pricing.model === "free" && "text-green bg-green/10",
                          tool.pricing.model === "freemium" && "text-blue bg-blue/10",
                          tool.pricing.model === "paid" && "text-yellow bg-yellow/10",
                          tool.pricing.model === "byok" && "text-text-muted bg-surface",
                        ]}
                      >
                        {tool.pricing.model}
                      </span>
                    </td>
                    <td class="py-3 hidden lg:table-cell text-text-muted text-xs font-mono">
                      {tool.license}
                    </td>
                  </tr>
                );
              })}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</Layout>
