---
import Layout from "../layouts/Layout.astro";
import { tools } from "../data/tools";
import { CATEGORIES, TOOL_COST_COLORS, AI_ACCESS_LABELS, AI_ACCESS_COLORS } from "../types";
import type { Category } from "../types";

const toolsByCategory = CATEGORIES.map((cat) => {
  const count = tools.filter(
    (t) => t.primaryCategory === cat.slug || t.secondaryCategories?.includes(cat.slug)
  ).length;
  return { ...cat, count };
});
---

<Layout title="Awesome Agent IDEs — AI Coding Tool Landscape">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <header class="mb-16">
      <h1 class="text-4xl font-semibold mb-4">
        The Agent IDE Landscape
      </h1>
      <p class="text-text-muted text-lg max-w-2xl">
        40+ AI coding tools across 7 categories. Stop comparing terminals to orchestrators.
        Find the right tool for your workflow.
      </p>
      <p class="text-text-muted text-xs font-mono mt-4 uppercase tracking-wider">
        {tools.length} tools verified &middot; March 2026
      </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-border">
      {toolsByCategory.map((cat) => (
        <a
          href={`/category/${cat.slug}`}
          class:list={[
            "group flex items-start gap-4 bg-bg p-5 transition-colors hover:bg-surface-hover",
            cat.count <= 1 && "opacity-70",
          ]}
        >
          <span class="font-mono text-xs font-medium text-accent bg-accent/10 px-2 py-1 shrink-0 tracking-wider">
            {cat.icon}
          </span>
          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between mb-1">
              <h2 class="text-base font-semibold group-hover:text-accent transition-colors">
                {cat.name}
              </h2>
              <span class="text-xs font-mono text-text-muted">
                {cat.count}
              </span>
            </div>
            <p class="text-xs text-text-muted leading-relaxed">
              {cat.description}
            </p>
            {cat.count <= 1 && (
              <span class="inline-block mt-2 text-xs text-yellow px-2 py-0.5 border border-yellow/30">
                Emerging
              </span>
            )}
          </div>
        </a>
      ))}
    </div>

    <section class="mt-20">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-2xl font-semibold">All Tools</h2>
        <span class="text-xs font-mono text-text-muted uppercase tracking-wider border-b border-border pb-px">
          {tools.length} entries
        </span>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border text-left">
              <th class="pb-3 pr-4 font-mono text-xs text-text-muted uppercase tracking-wider font-medium">Name</th>
              <th class="pb-3 pr-4 font-mono text-xs text-text-muted uppercase tracking-wider font-medium">Cat</th>
              <th class="pb-3 pr-4 font-mono text-xs text-text-muted uppercase tracking-wider font-medium hidden sm:table-cell">Platforms</th>
              <th class="pb-3 pr-4 font-mono text-xs text-text-muted uppercase tracking-wider font-medium hidden md:table-cell">Pricing</th>
              <th class="pb-3 font-mono text-xs text-text-muted uppercase tracking-wider font-medium hidden lg:table-cell">License</th>
            </tr>
          </thead>
          <tbody>
            {tools
              .sort((a, b) => a.name.localeCompare(b.name))
              .map((tool) => {
                const cat = CATEGORIES.find((c) => c.slug === tool.primaryCategory)!;
                return (
                  <tr class="border-b border-border/50 hover:bg-surface-hover transition-colors">
                    <td class="py-4 pr-4">
                      <a href={`/tool/${tool.slug}`} class="text-accent hover:text-accent-hover font-medium">
                        {tool.name}
                      </a>
                    </td>
                    <td class="py-3 pr-4 font-mono text-xs text-text-muted">{cat.icon}</td>
                    <td class="py-3 pr-4 text-text-muted hidden sm:table-cell font-mono text-xs">
                      {tool.platforms.join(", ")}
                    </td>
                    <td class="py-3 pr-4 hidden md:table-cell">
                      <span class:list={["text-xs px-2 py-0.5 font-mono", TOOL_COST_COLORS[tool.pricing.toolCost]]}>
                        {tool.pricing.toolCost}
                        {tool.pricing.startingPrice && ` · ${tool.pricing.startingPrice}`}
                      </span>
                      {!tool.pricing.aiAccess.includes("bundled") && !tool.pricing.aiAccess.includes("none") && (
                        <span class:list={["text-xs px-1.5 py-0.5 font-mono ml-1", AI_ACCESS_COLORS[tool.pricing.aiAccess[0]]]}>
                          {AI_ACCESS_LABELS[tool.pricing.aiAccess[0]]}
                        </span>
                      )}
                    </td>
                    <td class="py-4 hidden lg:table-cell text-text-muted text-xs font-mono">
                      {tool.license}
                    </td>
                  </tr>
                );
              })}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</Layout>
