---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Navigate the AI coding tool landscape. Compare orchestrators, terminals, IDEs, CLI agents, and more." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-bg text-text font-sans min-h-screen">
    <nav class="border-b border-border">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-lg font-semibold hover:text-accent transition-colors">
          <span class="text-accent font-mono">▲</span> Awesome Agent IDEs
        </a>
        <div class="flex items-center gap-6 text-sm text-text-muted">
          <a href="/" class="hover:text-text transition-colors">Home</a>
          <a href="/about" class="hover:text-text transition-colors">About</a>
          <a href="https://github.com/mulyoved/awesome-agent-ides" target="_blank" rel="noopener" class="hover:text-text transition-colors">
            GitHub
          </a>
        </div>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer class="border-t border-border mt-20">
      <div class="max-w-6xl mx-auto px-4 py-8 text-center text-sm text-text-muted">
        <p>Data last verified March 2026. <a href="https://github.com/mulyoved/awesome-agent-ides" class="text-accent hover:text-accent-hover">Contribute on GitHub</a>.</p>
      </div>
    </footer>
  </body>
</html>
